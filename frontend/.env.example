# =========================================================================
# MODELO DE CONFIGURAÇÃO DE AMBIENTE LOCAL (.env.example)
# Copie este arquivo para um novo chamado `.env` e ajuste as configurações locais.
# =========================================================================

# Configurações do App Flask/FastAPI
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=sua_chave_secreta_criptografica_aqui
PORT=5000

# Conectividade de Banco de Dados (SQLite para dev local, PostgreSQL para produção)
DATABASE_URL=sqlite:///gestao_obras.db
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/gestao_obras

# Integração de Comunicação Web/Mobile
NEXT_PUBLIC_API_URL=http://localhost:5030
